INCLUDE "lib/runtime.trine"
INCLUDE "lib/memory.trine"
INCLUDE "lib/control.trine"

DEF EVENT_COUNT 4

events: DATA 0, 1, 1, 0
table: DATA 1, 0, 1, 2, 0, 2

PUSH 0
STORE_CELL RT_STATE
PUSH 0
STORE_CELL RT_IDX

loop:
LOAD_CELL RT_IDX
PUSH EVENT_COUNT
SUB
JZ done

LOAD_CELL RT_IDX
PUSH events
ADD
LOAD
STORE_CELL RT_EVENT

LOAD_CELL RT_STATE
DUP
ADD
PUSH table
ADD
LOAD_CELL RT_EVENT
ADD
LOAD
STORE_CELL RT_STATE

LOAD_CELL RT_STATE
PRINT
INC_CELL RT_IDX
JMP loop

done:
HALT
